{
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git push:*)",
      "Bash(git tag:*)",
      "Bash(npm install)",
      "Bash(npm ci)",
      "Bash(npm run build:*)",
      "Bash(npm run dev:*)",
      "Bash(npm run lint:*)",
      "Bash(npm start:*)",
      "Bash(npm test:*)",
      "Bash(node:*)",
      "Bash(python3:*)",
      "Bash(psql:*)",
      "mcp__supabase-rasifiters__list_tables",
      "mcp__supabase-rasifiters__list_projects",
      "mcp__supabase-rasifiters__execute_sql",
      "mcp__supabase-rasifiters__get_logs",
      "mcp__supabase-rasifiters__get_advisors",
      "mcp__render__list_workspaces",
      "mcp__render__get_selected_workspace",
      "mcp__render__list_services",
      "mcp__render__get_service",
      "mcp__render__list_deploys",
      "mcp__render__get_deploy",
      "mcp__render__get_metrics",
      "mcp__render__list_logs",
      "mcp__render__list_log_label_values",
      "mcp__render__list_postgres_instances",
      "mcp__render__get_postgres",
      "mcp__render__list_key_value",
      "mcp__render__get_key_value"
    ],
    "deny": [
      "mcp__claude_ai_Supabase",
      "mcp__claude_ai_Vercel",
      "mcp__claude_ai_Google_Drive",
      "mcp__n8n"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/deploy-scope-guard.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/db-readonly-guard.sh\""
          }
        ]
      }
    ]
  },
  "outputStyle": "default"
}
