build/
# Firebase client config. Not a hard secret (it ships inside the APK), but the repo is PUBLIC and this
# machine is the sole builder — so we keep it OUT of git and place it per-machine at
# apps/android/app/google-services.json (Firebase console → project rasi-fiters → Android app → download).
# The google-services Gradle plugin requires the file present at build time.
app/google-services.json
google-services.json

# Release signing — HARD secrets. Repo is PUBLIC: the upload keystore + its passwords must NEVER be
# committed. The .jks itself lives OUTSIDE the repo (see keystore.properties.template); keystore.properties
# (path + passwords) is per-machine only. Losing the .jks is recoverable via Play App Signing key reset.
keystore.properties
*.jks
*.keystore
