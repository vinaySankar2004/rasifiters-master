<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Android 13+ runtime permission to post notifications (FCM push; requested at runtime — Phase I-b). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Health Connect (Phase H) — read-only workout + sleep access (the HealthKit READ analog). Granted
         via the Health Connect permission UI (PermissionController), not a runtime dialog. -->
    <uses-permission android:name="android.permission.health.READ_EXERCISE" />
    <uses-permission android:name="android.permission.health.READ_SLEEP" />
    <uses-permission android:name="android.permission.health.READ_STEPS" />

    <!-- Health Connect provider visibility (needed to resolve the client on Android 13 and lower, where
         Health Connect ships as a standalone app rather than built into the platform). -->
    <queries>
        <package android:name="com.google.android.apps.healthdata" />
        <intent>
            <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE" />
        </intent>
    </queries>

    <application
        android:name=".App"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.RaSiFiters"
        android:usesCleartextTraffic="true">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/Theme.RaSiFiters">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Deep-link scheme (parity with iOS rasifiters://); routes wired in a later phase. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="rasifiters" />
            </intent-filter>
            <!-- Health Connect permissions rationale (Android 13 and lower): opening the privacy-policy link
                 from the Health Connect permission sheet lands here (the app; Privacy Policy is reachable
                 in-app under My Account). -->
            <intent-filter>
                <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE" />
            </intent-filter>
        </activity>

        <!-- Health Connect permissions rationale (Android 14+): the platform routes the privacy-policy tap
             to this alias, which just opens the app (Privacy Policy lives under My Account). -->
        <activity-alias
            android:name="ViewPermissionUsageActivity"
            android:exported="true"
            android:targetActivity=".MainActivity"
            android:permission="android.permission.START_VIEW_PERMISSION_USAGE">
            <intent-filter>
                <action android:name="android.intent.action.VIEW_PERMISSION_USAGE" />
                <category android:name="android.intent.category.HEALTH_PERMISSIONS" />
            </intent-filter>
        </activity-alias>

        <!-- FCM push (Phase I-b) — receives new-token + message events. onNewToken re-registers the device;
             foreground messages defer to the in-app SSE modal, background ones are shown by the system tray. -->
        <service
            android:name=".push.RaSiFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
        <!-- Channel that background FCM "notification" messages post into (created in App.onCreate). -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="@string/default_notification_channel_id" />

        <!-- CSV export share target — the Members detail screens write a temp .csv to cache and share it
             (parity with the iOS ShareSheet export on metrics / workouts / health). -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- Quick-add home-screen widgets (Jetpack Glance) — the iOS WidgetKit AddWorkout / AddDailyHealth
             analog. Each receiver taps deep-link `rasifiters://quick-add-*` into MainActivity's VIEW filter. -->
        <receiver
            android:name=".widget.AddWorkoutWidgetReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/quick_add_workout_widget_info" />
        </receiver>
        <receiver
            android:name=".widget.AddDailyHealthWidgetReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/quick_add_health_widget_info" />
        </receiver>
    </application>
</manifest>
