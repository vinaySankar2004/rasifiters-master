<?xml version="1.0" encoding="utf-8"?>
<!-- Home-screen widget-picker preview (wide banner) for the quick-add-health Glance widget.
     Static layout mirroring AddDailyHealthWidget's redesigned state (hero glyph + short label + full-width
     CTA — D-ANDROID-WIDGET-4); reuses the same shape/icon drawables so the picker shows the real blue
     card instead of the generic app-icon placeholder. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:minWidth="250dp"
    android:minHeight="110dp"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="@drawable/widget_bg_health"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <FrameLayout
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/widget_icon_circle">
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_widget_plus"
                android:tint="#FFFFFFFF" />
        </FrameLayout>

        <!-- Empty TextView as a flexible spacer — bare <View> is not RemoteViews-whitelisted
             (previewLayout is inflated as RemoteViews by the launcher). -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_widget_chevron_right"
            android:tint="#BFFFFFFF" />
    </LinearLayout>

    <!-- Hero glyph -->
    <ImageView
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="16dp"
        android:src="@drawable/ic_widget_bed"
        android:tint="#FFFFFFFF" />

    <!-- Short label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Log health"
        android:textColor="#FFFFFFFF"
        android:textStyle="bold"
        android:textSize="16sp" />

    <!-- Full-width CTA -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/widget_capsule_translucent"
        android:paddingTop="9dp"
        android:paddingBottom="9dp">

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:src="@drawable/ic_widget_plus"
            android:tint="#FFFFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="Log day"
            android:textColor="#FFFFFFFF"
            android:textSize="13sp" />
    </LinearLayout>
</LinearLayout>
