<?xml version="1.0" encoding="utf-8"?>
<!-- Home-screen widget-picker preview (wide banner) for the quick-add-workout Glance widget.
     Static layout mirroring AddWorkoutWidget's expanded state; reuses the same shape/icon drawables
     so the picker shows the real orange card instead of the generic app-icon placeholder. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:minWidth="250dp"
    android:minHeight="110dp"
    android:orientation="vertical"
    android:background="@drawable/widget_bg_workout"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <FrameLayout
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/widget_icon_circle">
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_widget_plus"
                android:tint="#000000" />
        </FrameLayout>

        <!-- Empty TextView as a flexible spacer — bare <View> is not RemoteViews-whitelisted
             (previewLayout is inflated as RemoteViews by the launcher). -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_widget_chevron_right"
            android:tint="#99000000" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Add workout session"
        android:textColor="#000000"
        android:textStyle="bold"
        android:textSize="18sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxLines="2"
        android:text="Quick add a session for any program."
        android:textColor="#A6000000"
        android:textSize="13sp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/widget_capsule_orange"
        android:paddingLeft="14dp"
        android:paddingRight="14dp"
        android:paddingTop="7dp"
        android:paddingBottom="7dp">

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:src="@drawable/ic_widget_bolt"
            android:tint="#000000" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="Log session"
            android:textColor="#000000"
            android:textSize="13sp" />
    </LinearLayout>
</LinearLayout>
