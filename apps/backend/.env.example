# RaSi Fiters backend — environment template (copy to .env.local; never commit real values)
# Canonical runbook: ../../ENV_RUNBOOK.md. Faithful migration delta: specs/features/auth/SPEC.md §6/§7.

# --- Database (Supabase Postgres) -----------------------------------------------------------------
# Replaces the legacy DB_URL (Render). Use the Supabase session-pooler / direct connection string.
DATABASE_URL=postgresql://postgres:PASSWORD@HOST:5432/postgres

# --- Supabase Auth (the credential store + token issuer/verifier; R1) ----------------------------
SUPABASE_URL=https://kpadxjekpiwfkqcxtrio.supabase.co
SUPABASE_ANON_KEY=            # public anon key — used for the sign-in / refresh proxy
SUPABASE_SERVICE_ROLE_KEY=    # service-role key — used for admin createUser/updateUser/deleteUser
# JWT verification (D-C2): JWKS endpoint for the project's ASYMMETRIC signing keys (ES256).
# Defaults to ${SUPABASE_URL}/auth/v1/.well-known/jwks.json if unset.
# NOTE: the project must have JWT signing keys migrated to asymmetric (ECC P-256) in the Supabase
# dashboard (Auth → JWT Keys) for JWKS verification to find a key — see PROGRESS.md.
SUPABASE_JWKS_URL=
SUPABASE_JWT_ISS=            # optional issuer override; defaults to ${SUPABASE_URL}/auth/v1

# --- Server ---------------------------------------------------------------------------------------
PORT=5001
MIN_IOS_VERSION=1.2.0
