# tools/migrator/.env — copy to .env and fill (gitignored; never commit real values)

# SOURCE — legacy Render Postgres (read-only use). From backend/.env.local (DB_URL).
LEGACY_DATABASE_URL=postgresql://user:pass@dpg-xxxx.oregon-postgres.render.com/rasi_fiters_db

# TARGET — Supabase Postgres. Use the DIRECT or session-pooler connection string.
#   direct:         postgresql://postgres:<pw>@db.<ref>.supabase.co:5432/postgres
#   session pooler: postgresql://postgres.<ref>:<pw>@aws-1-us-east-1.pooler.supabase.com:5432/postgres
TARGET_DATABASE_URL=postgresql://postgres:<pw>@db.<ref>.supabase.co:5432/postgres

# TARGET — Supabase Auth admin (for the bcrypt-credential import). Service role key = full privilege.
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service_role_key>

# Members with no email get a synthesized placeholder: <username>@<PLACEHOLDER_EMAIL_DOMAIN>
# (username login still resolves to it server-side). Use a domain you control.
PLACEHOLDER_EMAIL_DOMAIN=no-email.rasifiters.com
