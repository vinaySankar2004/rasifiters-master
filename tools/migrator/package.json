{
  "name": "rasifiters-migrator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Temporary Render-PG → Supabase migrator for RaSi Fiters: copies legacy data (preserving member UUIDs) and imports bcrypt credentials into Supabase Auth.",
  "engines": { "node": ">=18" },
  "scripts": {
    "migrate": "node src/index.js",
    "verify": "node src/index.js --verify-only",
    "copy": "node src/index.js --copy-only",
    "auth": "node src/index.js --auth-only",
    "dry-run": "node src/index.js --dry-run"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "dotenv": "^16.4.5",
    "pg": "^8.12.0"
  }
}
